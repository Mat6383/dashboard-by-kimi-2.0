{
  "name": "testmo-dashboard-backend",
  "version": "1.0.0",
  "description": "Backend sécurisé pour dashboard Testmo - ISTQB compliant",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --testPathPatterns tests/",
    "test:coverage": "jest --testPathPatterns tests/ --coverage"
  },
  "jest": {
    "coverageThreshold": {
      "global": {
        "branches": 30,
        "functions": 45,
        "lines": 50,
        "statements": 50
      }
    },
    "collectCoverageFrom": [
      "services/**/*.js",
      "routes/**/*.js",
      "validators/**/*.js",
      "!services/logger.service.js",
      "!services/testmo.service.js",
      "!services/gitlab.service.js",
      "!services/sync.service.js",
      "!services/status-sync.service.js",
      "!services/auto-sync-config.service.js",
      "!services/report/**/*.js"
    ]
  },
  "keywords": [
    "testmo",
    "dashboard",
    "qa",
    "istqb",
    "lean"
  ],
  "author": "Matou - Neo-Logix QA Lead",
  "license": "ISC",
  "dependencies": {
    "@sentry/node": "^10.49.0",
    "axios": "^1.6.5",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "marked": "^4.3.0",
    "node-cron": "^4.2.1",
    "pptxgenjs": "^4.0.1",
    "winston": "^3.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
